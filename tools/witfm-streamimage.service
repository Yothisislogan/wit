[Unit]
Description=WIT-FM Stream Image Updater
After=network.target witfm.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/Witradio
Environment="PATH=/home/ubuntu/.local/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/home/ubuntu/Witradio/.venv/bin/python3 /home/ubuntu/Witradio/tools/update_stream_image.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
